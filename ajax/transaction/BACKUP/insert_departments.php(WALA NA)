<?php
session_start();

$db = new Postgresql();
$conn = $db->getConnection();

if (!isset($_SESSION['ppc']) || !isset($_SESSION['ppc']['emp_no'])) {
    echo json_encode(['status' => 'error', 'message' => 'Session expired. Please log in again.']);
    exit;
}

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $dept_name = isset($_POST['dept_name']) ? trim($_POST['dept_name']) : '';
    $dept_code = isset($_POST['dept_code']) ? trim($_POST['dept_code']) : '';
    $group_id  = isset($_POST['dept_group_id']) ? trim($_POST['dept_group_id']) : '';
    $added_by  = isset($_POST['added_by']) ? strtoupper($_POST['added_by']) : strtoupper($_SESSION['ppc']['fullname']);
    $active    = isset($_POST['active']) ? $_POST['active'] : 'true';
    $emp_no    = $_SESSION['ppc']['emp_no'];

    if ($dept_name === '' || $dept_code === '' || $group_id === '') {
        echo json_encode(['status' => 'error', 'message' => 'Missing required fields.']);
        exit;
    }

    $query = "
        INSERT INTO M_ACC_DEPARTMENTS_TBL 
        (dept_name, dept_code, group_id, added_by, active, employee_no)
        VALUES ($1, $2, $3, $4, $5, $6)
        RETURNING id, dept_name, dept_code, group_id, added_by, active, employee_no
    ";

    $params = [$dept_name, $dept_code, $group_id, $added_by, $active, $emp_no];
    $result = pg_query_params($conn, $query, $params);

    if ($result && ($row = pg_fetch_assoc($result))) {
        echo json_encode(['status' => 'success', 'new' => $row]);
    } else {
        echo json_encode(['status' => 'error', 'message' => 'Insert failed.']);
    }

} else {
    echo json_encode(['status' => 'error', 'message' => 'Invalid request method.']);
}
?>
